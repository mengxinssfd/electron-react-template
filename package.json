{
  "name": "electron-react-template",
  "version": "0.0.0",
  "description": "electron react template",
  "keywords": [
    "electron",
    "react"
  ],
  "homepage": "https://github.com/mengxinssfd/electron-react-template#readme",
  "bugs": {
    "url": "https://github.com/mengxinssfd/electron-react-template/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mengxinssfd/electron-react-template.git"
  },
  "license": "MIT",
  "author": "DYH",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "npm run ts-check:* && vite build && electron-builder",
    "build:only": "vite build && electron-builder",
    "build:electron-only": "electron-builder",
    "build:mac": "npm run ts-check:* && vite build && electron-builder --mac",
    "build:win": "npm run ts-check:* && vite build && electron-builder --win",
    "build:linux": "npm run ts-check:* && vite build && electron-builder --linux",
    "prepare": "husky",
    "ts-check:src": "tsc -p ./tsconfig.json --noEmit",
    "ts-check:node": "tsc -p ./tsconfig.node.json --noEmit",
    "ts-check:*": "pnpm ts-check:src & pnpm ts-check:node",
    "lint:check": "eslint . --quiet",
    "lint:fix": "eslint . --fix"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,html,md}": [
      "eslint",
      "git add"
    ]
  },
  "dependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vite-electron-plugin": "^0.8.3"
  }
}
